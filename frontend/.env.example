# Credenciales de Supabase para CPHS Gestor (BaaS Cloud Database)
# Copia este archivo como '.env' en esta misma carpeta y reemplaza con tus claves reales.
# Estas mismas variables deben configurarse en el panel de Vercel.

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-publica-anon-key
